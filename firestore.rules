rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentRole() {
      return currentUser().role;
    }

    function currentCompanyId() {
      return currentUser().companyId;
    }

    function isOwnerRole() {
      return isSignedIn() && currentRole() == "owner";
    }

    function isAdminRole() {
      return isSignedIn() && currentRole() == "admin";
    }

    function isSalesRole() {
      return isSignedIn() && currentRole() == "sales";
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidRole(role) {
      return role == "owner" || role == "admin" || role == "sales";
    }

    function isValidUserStatus(status) {
      return status == "active" || status == "inactive";
    }

    function isValidCompanyStatus(status) {
      return status == "active" || status == "inactive" || status == "suspended";
    }

    function isValidCompanyPlan(plan) {
      return plan == "standard" || plan == "pro" || plan == "enterprise";
    }

    function isValidUploadDurationLimitMinutes(limitMinutes) {
      return limitMinutes == 60 || limitMinutes == 120 || limitMinutes == 180 || limitMinutes == 240;
    }

    function isValidMonthlyAiQuota(quota) {
      return quota is number && quota >= 0;
    }

    function isValidOptionalMonthlyAiQuota(quota) {
      return quota == null || isValidMonthlyAiQuota(quota);
    }

    function companyUploadDurationLimitMinutes(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId))
        && isValidUploadDurationLimitMinutes(get(/databases/$(database)/documents/companies/$(companyId)).data.uploadDurationLimitMinutes)
        ? get(/databases/$(database)/documents/companies/$(companyId)).data.uploadDurationLimitMinutes
        : 60;
    }

    function effectiveUploadDurationLimitSec(companyId) {
      return (companyUploadDurationLimitMinutes(companyId) + 3) * 60;
    }

    function hasValidUploadDuration(companyId) {
      return !("audioFileName" in request.resource.data)
        || request.resource.data.audioFileName == null
        || (
          request.resource.data.audioDurationSec is number
          && request.resource.data.audioDurationSec >= 0
          && request.resource.data.audioDurationSec <= effectiveUploadDurationLimitSec(companyId)
        );
    }

    function isUploadDurationRelevantUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        "audioFileName",
        "audioFilePath",
        "audioDownloadUrl",
        "audioSizeBytes",
        "audioMimeType",
        "audioDurationSec"
      ]);
    }

    function sameCompany(companyId) {
      return isSignedIn() && companyId is string && companyId == currentCompanyId();
    }

    function hasSalesDomain(domain) {
      return isSignedIn()
        && (!("enabledSalesDomains" in currentUser())
          || !(domain in currentUser().enabledSalesDomains)
          || currentUser().enabledSalesDomains[domain] == true);
    }

    function canUseMeetingDomain() {
      return isOwnerRole() || isAdminRole() || (isSalesRole() && hasSalesDomain("meeting"));
    }

    function canUseTeleapoDomain() {
      return isOwnerRole() || isAdminRole() || (isSalesRole() && hasSalesDomain("teleapo"));
    }

    function canReadCompanyData(companyId) {
      return isOwnerRole() || sameCompany(companyId);
    }

    function canAdminCompanyData(companyId) {
      return isOwnerRole() || (isAdminRole() && sameCompany(companyId));
    }

    function isKnowledgeCategoryCounterUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["knowledgeCount", "memoCount", "updatedAt"])
        && request.resource.data.knowledgeCount is int
        && request.resource.data.memoCount is int;
    }

    function isKnowledgeProductCounterUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["knowledgeCount", "updatedAt"])
        && request.resource.data.knowledgeCount is int;
    }

    function isKnowledgeProductTabsUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["tabs", "updatedAt"])
        && request.resource.data.tabs is list;
    }

    match /companies/{companyId} {
      allow read: if isOwnerRole() || sameCompany(companyId);
      allow create: if isSignedIn()
        && request.resource.data.companyName is string
        && isValidCompanyPlan(request.resource.data.plan)
        && isValidCompanyStatus(request.resource.data.status)
        && isValidMonthlyAiQuota(request.resource.data.monthlyTranscriptionQuota)
        && isValidMonthlyAiQuota(request.resource.data.monthlyRoleplayQuota)
        && (!("uploadDurationLimitMinutes" in request.resource.data)
          || isValidUploadDurationLimitMinutes(request.resource.data.uploadDurationLimitMinutes));
      allow update: if isOwnerRole()
        && (!("plan" in request.resource.data) || isValidCompanyPlan(request.resource.data.plan))
        && (!("status" in request.resource.data) || isValidCompanyStatus(request.resource.data.status))
        && (!("monthlyTranscriptionQuota" in request.resource.data)
          || isValidOptionalMonthlyAiQuota(request.resource.data.monthlyTranscriptionQuota))
        && (!("monthlyRoleplayQuota" in request.resource.data)
          || isValidOptionalMonthlyAiQuota(request.resource.data.monthlyRoleplayQuota))
        && (!("uploadDurationLimitMinutes" in request.resource.data)
          || isValidUploadDurationLimitMinutes(request.resource.data.uploadDurationLimitMinutes));
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isOwnerRole() || isSelf(userId) || (isAdminRole() && sameCompany(resource.data.companyId));
      allow create: if (
          isSelf(userId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.companyId is string
          && isValidRole(request.resource.data.role)
          && isValidUserStatus(request.resource.data.status)
        )
        || (
          isOwnerRole()
          && request.resource.data.uid == userId
          && request.resource.data.companyId is string
          && (request.resource.data.role == "admin" || request.resource.data.role == "sales")
          && isValidUserStatus(request.resource.data.status)
        )
        || (
          isAdminRole()
          && request.resource.data.uid == userId
          && request.resource.data.companyId == currentCompanyId()
          && request.resource.data.role == "sales"
          && isValidUserStatus(request.resource.data.status)
        );
      allow update: if isOwnerRole()
        || (
          isAdminRole()
          && sameCompany(resource.data.companyId)
          && request.resource.data.companyId == resource.data.companyId
          && request.resource.data.role != "owner"
        )
        || (
          isSelf(userId)
          && request.resource.data.companyId == resource.data.companyId
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.email == resource.data.email
        );
      allow delete: if false;

      match /knowledgeSearchHistory/{historyId} {
        allow read: if isOwnerRole() || isSelf(userId);
        allow write: if isSelf(userId);
      }
    }

    match /meetings/{meetingId} {
      allow read: if canUseMeetingDomain()
        && canReadCompanyData(resource.data.companyId)
        && (isOwnerRole() || isAdminRole() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && canUseMeetingDomain()
        && request.resource.data.userId == request.auth.uid
        && sameCompany(request.resource.data.companyId)
        && hasValidUploadDuration(request.resource.data.companyId);
      allow update: if (
          canAdminCompanyData(resource.data.companyId)
          || (canUseMeetingDomain() && isSelf(resource.data.userId) && sameCompany(resource.data.companyId))
        )
        && (!isUploadDurationRelevantUpdate() || hasValidUploadDuration(resource.data.companyId));
      allow delete: if false;

      match /{subcollection}/{documentId} {
        allow read: if canUseMeetingDomain()
          && canReadCompanyData(get(/databases/$(database)/documents/meetings/$(meetingId)).data.companyId);
        allow write: if canAdminCompanyData(get(/databases/$(database)/documents/meetings/$(meetingId)).data.companyId);
      }
    }

    match /meetingOutcomeHistory/{historyId} {
      allow read, write: if isOwnerRole() || isAdminRole();
    }

    match /monthlyStats/{month} {
      allow read: if isOwnerRole() || isAdminRole();
      allow write: if isOwnerRole() || isAdminRole();
    }

    match /userMonthlyStats/{documentId} {
      allow read: if isOwnerRole() || isAdminRole() || isSelf(resource.data.userId);
      allow write: if isOwnerRole() || isAdminRole();
    }

    match /manualChecklists/{checklistId} {
      allow read: if isSignedIn();
      allow write: if isOwnerRole() || isAdminRole();
    }

    match /knowledgeCategories/{categoryId} {
      allow read: if canUseMeetingDomain() && canReadCompanyData(resource.data.companyId);
      allow create: if isSignedIn()
        && canUseMeetingDomain()
        && request.resource.data.createdBy == request.auth.uid
        && sameCompany(request.resource.data.companyId);
      allow update: if canAdminCompanyData(resource.data.companyId)
        || (resource.data.createdBy == request.auth.uid && sameCompany(resource.data.companyId))
        || isKnowledgeCategoryCounterUpdate();
      allow delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /knowledgeProducts/{productId} {
      allow read: if canUseMeetingDomain() && canReadCompanyData(resource.data.companyId);
      allow create: if isSignedIn()
        && canUseMeetingDomain()
        && request.resource.data.createdBy == request.auth.uid
        && sameCompany(request.resource.data.companyId);
      allow update: if canAdminCompanyData(resource.data.companyId)
        || (resource.data.createdBy == request.auth.uid && sameCompany(resource.data.companyId))
        || isKnowledgeProductCounterUpdate()
        || isKnowledgeProductTabsUpdate();
      allow delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /knowledgeItems/{knowledgeId} {
      allow read: if canUseMeetingDomain()
        && canReadCompanyData(resource.data.companyId)
        && (resource.data.scope == "shared" || resource.data.ownerId == request.auth.uid || isAdminRole() || isOwnerRole());
      allow create: if isSignedIn()
        && canUseMeetingDomain()
        && request.resource.data.ownerId == request.auth.uid
        && sameCompany(request.resource.data.companyId)
        && (request.resource.data.scope == "personal" || isAdminRole() || isOwnerRole());
      allow update: if canAdminCompanyData(resource.data.companyId)
        || (
          resource.data.ownerId == request.auth.uid
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.companyId == resource.data.companyId
          && request.resource.data.scope == "personal"
        );
      allow delete: if canAdminCompanyData(resource.data.companyId) || resource.data.ownerId == request.auth.uid;
    }

    match /roleplayScenarios/{scenarioId} {
      allow read: if canUseTeleapoDomain() && canReadCompanyData(resource.data.companyId);
      allow create: if canAdminCompanyData(request.resource.data.companyId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /roleplayResults/{resultId} {
      allow read: if canUseTeleapoDomain()
        && canReadCompanyData(resource.data.companyId)
        && (isOwnerRole() || isAdminRole() || resource.data.userId == request.auth.uid);
      allow create: if false;
      allow update, delete: if false;
    }

    match /systemErrors/{errorId} {
      allow read, update: if isOwnerRole();
      allow create: if isOwnerRole() || (isSignedIn() && (!("companyId" in request.resource.data) || sameCompany(request.resource.data.companyId)));
      allow delete: if false;
    }

    match /loginEvents/{eventId} {
      allow read: if isOwnerRole();
      allow create: if request.resource.data.email is string
        && request.resource.data.status in ["success", "failed"]
        && request.resource.data.createdAt is timestamp
        && (
          (
            request.resource.data.status == "failed"
            && request.resource.data.uid == null
          )
          || (
            isSignedIn()
            && request.resource.data.status == "success"
            && request.resource.data.uid == request.auth.uid
          )
        );
      allow update, delete: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read: if isOwnerRole()
        || (
          isAdminRole()
          && (
            resource.data.actorId == request.auth.uid
            || sameCompany(resource.data.companyId)
          )
        );
      allow create: if (isOwnerRole() || isAdminRole())
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string
        && request.resource.data.createdAt is timestamp
        && (
          isOwnerRole()
          || sameCompany(request.resource.data.companyId)
        );
      allow update, delete: if false;
    }

    match /aiUsageLogs/{logId} {
      allow read: if isOwnerRole() || canReadCompanyData(resource.data.companyId);
      allow create: if isOwnerRole() || (isSignedIn() && sameCompany(request.resource.data.companyId));
      allow update, delete: if false;
    }

    match /aiChargeEvents/{eventId} {
      allow read, create, update: if isOwnerRole();
      allow delete: if false;
    }

    match /knowledgeSearchEvents/{eventId} {
      allow read: if isOwnerRole() || canReadCompanyData(resource.data.companyId);
      allow create: if isOwnerRole() || (
        isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && sameCompany(request.resource.data.companyId)
      );
      allow update, delete: if false;
    }

    match /audioProcessingJobs/{jobId} {
      allow read: if isOwnerRole() || canReadCompanyData(resource.data.companyId);
      allow create, update: if isOwnerRole() || (isSignedIn() && sameCompany(request.resource.data.companyId));
      allow delete: if false;
    }

    match /aiPrompts/{promptId} {
      allow read, create, update: if isOwnerRole();
      allow delete: if false;
    }

    match /featureFlags/{flagId} {
      allow read, create, update: if isOwnerRole();
      allow delete: if false;
    }

    match /announcements/{announcementId} {
      allow read, create, update: if isOwnerRole();
      allow delete: if false;
    }
  }
}
