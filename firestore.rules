rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentRole() {
      return currentUser().role;
    }

    function currentCompanyId() {
      return currentUser().companyId;
    }

    function isOwnerRole() {
      return isSignedIn() && currentRole() == "owner";
    }

    function isAdminRole() {
      return isSignedIn() && currentRole() == "admin";
    }

    function isSalesRole() {
      return isSignedIn() && currentRole() == "sales";
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidRole(role) {
      return role == "owner" || role == "admin" || role == "sales";
    }

    function isValidUserStatus(status) {
      return status == "active" || status == "inactive";
    }

    function isValidCompanyStatus(status) {
      return status == "active" || status == "inactive" || status == "suspended";
    }

    function isValidCompanyPlan(plan) {
      return plan == "standard" || plan == "pro" || plan == "enterprise";
    }

    function isValidUploadDurationLimitMinutes(value) {
      return value == 60 || value == 120 || value == 180 || value == 240;
    }

    function isValidMonthlyAiQuota(quota) {
      return quota is number && quota >= 0;
    }

    function isValidOptionalMonthlyAiQuota(quota) {
      return quota == null || isValidMonthlyAiQuota(quota);
    }

    function sameCompany(companyId) {
      return isSignedIn() && companyId is string && companyId == currentCompanyId();
    }

    function canReadCompanyData(companyId) {
      return isOwnerRole() || sameCompany(companyId);
    }

    function canAdminCompanyData(companyId) {
      return isOwnerRole() || (isAdminRole() && sameCompany(companyId));
    }

    function canUseMeetingDomain() {
      return isOwnerRole()
        || isAdminRole()
        || !("enabledSalesDomains" in currentUser())
        || !("meeting" in currentUser().enabledSalesDomains)
        || currentUser().enabledSalesDomains.meeting == true;
    }

    function canUseTeleapoDomain() {
      return isOwnerRole()
        || isAdminRole()
        || !("enabledSalesDomains" in currentUser())
        || !("teleapo" in currentUser().enabledSalesDomains)
        || currentUser().enabledSalesDomains.teleapo == true;
    }

    function canUseRoleplayDomain() {
      return canUseMeetingDomain() || canUseTeleapoDomain();
    }

    function canUseKnowledgeDomain() {
      return canUseMeetingDomain() || canUseTeleapoDomain();
    }

    function canUseMeetingDocument(data) {
      return (
          ("salesDomain" in data)
          && data.salesDomain == "teleapo"
          && canUseTeleapoDomain()
        )
        || (
          (!("salesDomain" in data) || data.salesDomain != "teleapo")
          && canUseMeetingDomain()
        );
    }

    function companyData(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)).data;
    }

    function canUseUploadDurationLimit(data) {
      return (
          (!("audioDurationSec" in data) || data.audioDurationSec == null)
          && (!("audioFileName" in data) || data.audioFileName == null)
          && (!("audioSizeBytes" in data) || data.audioSizeBytes == null)
        )
        || (
          data.audioDurationSec is number
          && (
            (!("uploadDurationLimitMinutes" in companyData(data.companyId)) && data.audioDurationSec <= 63 * 60)
            || (companyData(data.companyId).uploadDurationLimitMinutes == 60 && data.audioDurationSec <= 63 * 60)
            || (companyData(data.companyId).uploadDurationLimitMinutes == 120 && data.audioDurationSec <= 123 * 60)
            || (companyData(data.companyId).uploadDurationLimitMinutes == 180 && data.audioDurationSec <= 183 * 60)
            || (companyData(data.companyId).uploadDurationLimitMinutes == 240 && data.audioDurationSec <= 243 * 60)
          )
        );
    }

    function isKnowledgeCategoryCounterUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["knowledgeCount", "memoCount", "updatedAt"])
        && request.resource.data.knowledgeCount is int
        && request.resource.data.memoCount is int;
    }

    function isKnowledgeProductCounterUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["knowledgeCount", "updatedAt"])
        && request.resource.data.knowledgeCount is int;
    }

    function isKnowledgeProductTabsUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["tabs", "updatedAt"])
        && request.resource.data.tabs is list;
    }

    function isAdminUserCoachingUpdate() {
      return isAdminRole()
        && sameCompany(resource.data.companyId)
        && resource.data.role != "owner"
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "nextCoachingMemo",
          "nextCoachingMemoUpdatedAt",
          "nextCoachingMemoUpdatedBy",
          "adminCoachingStatus",
          "adminCoachingPriority",
          "adminCoachingReason",
          "adminNextActionTitle",
          "adminNextActionNote",
          "adminNextActionDueDate",
          "adminNextActionUpdatedAt",
          "adminNextActionUpdatedBy",
          "adminReviewStatus",
          "adminLastReviewedAt",
          "adminNextReviewDate",
          "adminReviewMemo",
          "adminReviewUpdatedAt",
          "adminReviewUpdatedBy",
          "updatedAt"
        ]);
    }

    match /companies/{companyId} {
      allow read: if isOwnerRole() || sameCompany(companyId);
      allow create: if isSignedIn()
        && request.resource.data.companyName is string
        && isValidCompanyPlan(request.resource.data.plan)
        && isValidCompanyStatus(request.resource.data.status)
        && (!("monthlyTranscriptionQuota" in request.resource.data)
          || isValidMonthlyAiQuota(request.resource.data.monthlyTranscriptionQuota))
        && (!("monthlyRoleplayQuota" in request.resource.data)
          || isValidMonthlyAiQuota(request.resource.data.monthlyRoleplayQuota))
        && (!("uploadDurationLimitMinutes" in request.resource.data) || isValidUploadDurationLimitMinutes(request.resource.data.uploadDurationLimitMinutes));
      allow update: if (
          isOwnerRole()
          && (!("plan" in request.resource.data) || isValidCompanyPlan(request.resource.data.plan))
          && (!("status" in request.resource.data) || isValidCompanyStatus(request.resource.data.status))
          && (!("monthlyTranscriptionQuota" in request.resource.data)
            || isValidOptionalMonthlyAiQuota(request.resource.data.monthlyTranscriptionQuota))
          && (!("monthlyRoleplayQuota" in request.resource.data)
            || isValidOptionalMonthlyAiQuota(request.resource.data.monthlyRoleplayQuota))
          && (!("uploadDurationLimitMinutes" in request.resource.data) || isValidUploadDurationLimitMinutes(request.resource.data.uploadDurationLimitMinutes))
        )
        || (
          isAdminRole()
          && sameCompany(companyId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["notificationEmails", "uploadDurationLimitMinutes", "updatedAt"])
          && (!("notificationEmails" in request.resource.data) || (request.resource.data.notificationEmails is list && request.resource.data.notificationEmails.size() <= 3))
          && (!("uploadDurationLimitMinutes" in request.resource.data) || isValidUploadDurationLimitMinutes(request.resource.data.uploadDurationLimitMinutes))
        );
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isOwnerRole()
        || isSelf(userId)
        || ((isAdminRole() || isSalesRole()) && sameCompany(resource.data.companyId));
      allow create: if (
          isSelf(userId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.companyId is string
          && isValidRole(request.resource.data.role)
          && isValidUserStatus(request.resource.data.status)
        )
        || (
          isOwnerRole()
          && request.resource.data.uid == userId
          && request.resource.data.companyId is string
          && (request.resource.data.role == "admin" || request.resource.data.role == "sales")
          && isValidUserStatus(request.resource.data.status)
        )
        || (
          isAdminRole()
          && request.resource.data.uid == userId
          && request.resource.data.companyId == currentCompanyId()
          && request.resource.data.role == "sales"
          && isValidUserStatus(request.resource.data.status)
        );
      allow update: if isOwnerRole()
        || isAdminUserCoachingUpdate()
        || (
          isAdminRole()
          && sameCompany(resource.data.companyId)
          && request.resource.data.companyId == resource.data.companyId
          && request.resource.data.role != "owner"
        )
        || (
          isSelf(userId)
          && request.resource.data.companyId == resource.data.companyId
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.email == resource.data.email
        );
      allow delete: if canAdminCompanyData(resource.data.companyId)
        || (isSelf(resource.data.userId) && sameCompany(resource.data.companyId) && canUseMeetingDocument(resource.data));

      match /knowledgeSearchHistory/{historyId} {
        allow read: if isOwnerRole() || isSelf(userId);
        allow write: if isSelf(userId) && canUseKnowledgeDomain();
      }
    }

    match /meetings/{meetingId} {
      allow read: if isOwnerRole()
        || (
          canReadCompanyData(resource.data.companyId)
          && canUseMeetingDocument(resource.data)
          && (isAdminRole() || resource.data.userId == request.auth.uid)
        )
        || (
          isSignedIn()
          && !("companyId" in resource.data)
          && resource.data.userId == request.auth.uid
        );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && sameCompany(request.resource.data.companyId)
        && canUseMeetingDocument(request.resource.data)
        && canUseUploadDurationLimit(request.resource.data);
      allow update: if canAdminCompanyData(resource.data.companyId) || (isSelf(resource.data.userId) && sameCompany(resource.data.companyId) && canUseMeetingDocument(resource.data));
      allow delete: if canAdminCompanyData(resource.data.companyId)
        || (isSelf(resource.data.userId) && sameCompany(resource.data.companyId) && canUseMeetingDocument(resource.data));

      match /{subcollection}/{documentId} {
        allow read: if canReadCompanyData(get(/databases/$(database)/documents/meetings/$(meetingId)).data.companyId);
        allow write: if canAdminCompanyData(get(/databases/$(database)/documents/meetings/$(meetingId)).data.companyId);
      }
    }

    match /customers/{customerId} {
      allow read: if isOwnerRole()
        || (
          canReadCompanyData(resource.data.companyId)
          && (isAdminRole() || resource.data.assignedUserId == request.auth.uid)
        );
      allow create: if isSignedIn()
        && sameCompany(request.resource.data.companyId)
        && (
          isAdminRole()
          || (
            isSalesRole()
            && request.resource.data.assignedUserId == request.auth.uid
          )
        );
      allow update: if canAdminCompanyData(resource.data.companyId)
        || (
          isSalesRole()
          && resource.data.assignedUserId == request.auth.uid
          && sameCompany(resource.data.companyId)
          && request.resource.data.companyId == resource.data.companyId
          && request.resource.data.assignedUserId == resource.data.assignedUserId
        );
      allow delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /customerLogs/{logId} {
      allow read: if isOwnerRole()
        || (
          canReadCompanyData(resource.data.companyId)
          && (isAdminRole() || resource.data.userId == request.auth.uid || resource.data.createdBy == request.auth.uid)
        );
      allow create: if isSignedIn()
        && sameCompany(request.resource.data.companyId)
        && (
          isAdminRole()
          || request.resource.data.userId == request.auth.uid
          || request.resource.data.createdBy == request.auth.uid
        );
      allow update, delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /customerMeetings/{linkId} {
      allow read: if canReadCompanyData(resource.data.companyId);
      allow create: if isSignedIn()
        && sameCompany(request.resource.data.companyId);
      allow update, delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /meetingOutcomeHistory/{historyId} {
      allow read, write: if isOwnerRole() || isAdminRole();
    }

    match /calendarEvents/{eventId} {
      allow read: if canReadCompanyData(resource.data.companyId)
        && (canUseMeetingDocument(resource.data) || canUseRoleplayDomain());
      allow create: if isSignedIn()
        && sameCompany(request.resource.data.companyId)
        && request.resource.data.userId == request.auth.uid
        && canUseMeetingDocument(request.resource.data);
      allow update: if canAdminCompanyData(resource.data.companyId)
        || (isSelf(resource.data.userId) && sameCompany(resource.data.companyId) && canUseMeetingDocument(resource.data));
      allow delete: if canAdminCompanyData(resource.data.companyId)
        || (isSelf(resource.data.userId) && sameCompany(resource.data.companyId) && canUseMeetingDocument(resource.data));
    }

    match /monthlyStats/{month} {
      allow read: if isOwnerRole() || isAdminRole();
      allow write: if isOwnerRole() || isAdminRole();
    }

    match /userMonthlyStats/{documentId} {
      allow read: if isOwnerRole() || isAdminRole() || isSelf(resource.data.userId);
      allow write: if isOwnerRole() || isAdminRole();
    }

    match /manualChecklists/{checklistId} {
      allow read: if isOwnerRole() || isAdminRole();
      allow write: if isOwnerRole() || isAdminRole();
    }

    match /salesManuals/{manualId} {
      allow read: if canReadCompanyData(resource.data.companyId) && canUseMeetingDomain();
      allow create: if canAdminCompanyData(request.resource.data.companyId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /knowledgeCategories/{categoryId} {
      allow read: if canReadCompanyData(resource.data.companyId) && canUseKnowledgeDomain();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && sameCompany(request.resource.data.companyId)
        && canUseKnowledgeDomain();
      allow update: if canAdminCompanyData(resource.data.companyId)
        || (resource.data.createdBy == request.auth.uid && sameCompany(resource.data.companyId) && canUseKnowledgeDomain())
        || isKnowledgeCategoryCounterUpdate();
      allow delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /knowledgeProducts/{productId} {
      allow read: if canReadCompanyData(resource.data.companyId);
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && sameCompany(request.resource.data.companyId)
        && canUseKnowledgeDomain();
      allow update: if canAdminCompanyData(resource.data.companyId)
        || (resource.data.createdBy == request.auth.uid && sameCompany(resource.data.companyId) && canUseKnowledgeDomain())
        || isKnowledgeProductCounterUpdate()
        || isKnowledgeProductTabsUpdate();
      allow delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /knowledgeItems/{knowledgeId} {
      allow read: if canReadCompanyData(resource.data.companyId)
        && canUseKnowledgeDomain()
        && (
          resource.data.scope == "shared"
          || resource.data.ownerId == request.auth.uid
          || (("sharedWithUserIds" in resource.data) && request.auth.uid in resource.data.sharedWithUserIds)
          || isAdminRole()
          || isOwnerRole()
        );
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && sameCompany(request.resource.data.companyId)
        && canUseKnowledgeDomain()
        && (request.resource.data.scope == "personal" || request.resource.data.scope == "shared");
      allow update: if canAdminCompanyData(resource.data.companyId)
        || (
          resource.data.ownerId == request.auth.uid
          && canUseKnowledgeDomain()
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.companyId == resource.data.companyId
          && (request.resource.data.scope == "personal" || request.resource.data.scope == "shared")
        );
      allow delete: if canAdminCompanyData(resource.data.companyId) || (resource.data.ownerId == request.auth.uid && canUseKnowledgeDomain());
    }

    match /roleplayScenarios/{scenarioId} {
      allow read: if canReadCompanyData(resource.data.companyId) && canUseRoleplayDomain();
      allow create: if canAdminCompanyData(request.resource.data.companyId)
        && request.resource.data.createdBy == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && sameCompany(request.resource.data.companyId)
        && canUseRoleplayDomain();
      allow update: if canAdminCompanyData(resource.data.companyId)
        || (
          resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.companyId == resource.data.companyId
          && sameCompany(resource.data.companyId)
          && canUseRoleplayDomain()
        );
      allow delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /roleplayTalkGuides/{guideId} {
      allow read: if canReadCompanyData(resource.data.companyId) && canUseRoleplayDomain();
      allow create: if canAdminCompanyData(request.resource.data.companyId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if canAdminCompanyData(resource.data.companyId);
    }

    match /roleplayResults/{resultId} {
      allow read: if canReadCompanyData(resource.data.companyId)
        && canUseRoleplayDomain()
        && (isOwnerRole() || isAdminRole() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && sameCompany(request.resource.data.companyId)
        && canUseRoleplayDomain();
      allow update: if false;
      allow delete: if canAdminCompanyData(resource.data.companyId)
        || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
          && sameCompany(resource.data.companyId)
          && canUseRoleplayDomain()
        );
    }

    match /roleplaySessions/{sessionId} {
      allow read: if canReadCompanyData(resource.data.companyId)
        && canUseRoleplayDomain()
        && (isOwnerRole() || isAdminRole() || resource.data.userId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /roleplayResultComments/{commentId} {
      allow read: if canReadCompanyData(resource.data.companyId)
        && canUseRoleplayDomain()
        && (isOwnerRole() || isAdminRole() || resource.data.userId == request.auth.uid);
      allow create: if canAdminCompanyData(request.resource.data.companyId)
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    match /roleplayAssignments/{assignmentId} {
      allow read: if canReadCompanyData(resource.data.companyId)
        && canUseRoleplayDomain()
        && (isOwnerRole() || isAdminRole() || resource.data.userId == request.auth.uid);
      allow create: if canAdminCompanyData(request.resource.data.companyId)
        && request.resource.data.assignedBy == request.auth.uid;
      allow update: if isSignedIn()
        && sameCompany(resource.data.companyId)
        && canUseRoleplayDomain()
        && (
          canAdminCompanyData(resource.data.companyId)
          || resource.data.userId == request.auth.uid
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "completedAt"]);
      allow delete: if false;
    }

    match /systemErrors/{errorId} {
      allow read, update: if isOwnerRole();
      allow create: if isOwnerRole() || (isSignedIn() && (!("companyId" in request.resource.data) || sameCompany(request.resource.data.companyId)));
      allow delete: if false;
    }

    match /loginEvents/{eventId} {
      allow read: if isOwnerRole();
      allow create: if request.resource.data.email is string
        && request.resource.data.status in ["success", "failed"]
        && request.resource.data.createdAt is timestamp
        && (
          (
            request.resource.data.status == "failed"
            && request.resource.data.uid == null
          )
          || (
            isSignedIn()
            && request.resource.data.status == "success"
            && request.resource.data.uid == request.auth.uid
          )
        );
      allow update, delete: if false;
    }

    match /adminAuditLogs/{logId} {
      allow read: if isOwnerRole()
        || (
          isAdminRole()
          && (
            resource.data.actorId == request.auth.uid
            || sameCompany(resource.data.companyId)
          )
        );
      allow create: if (isOwnerRole() || isAdminRole())
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.action is string
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string
        && request.resource.data.createdAt is timestamp
        && (
          isOwnerRole()
          || sameCompany(request.resource.data.companyId)
        );
      allow update, delete: if false;
    }

    match /aiUsageLogs/{logId} {
      allow read: if isOwnerRole() || canReadCompanyData(resource.data.companyId);
      allow create: if isOwnerRole() || (isSignedIn() && sameCompany(request.resource.data.companyId));
      allow update, delete: if false;
    }

    match /aiChargeEvents/{eventId} {
      allow read, create, update: if isOwnerRole();
      allow delete: if false;
    }

    match /emailEvents/{eventId} {
      allow read: if isOwnerRole() || canReadCompanyData(resource.data.companyId);
      allow create, update: if isOwnerRole();
      allow delete: if false;
    }

    match /appNotifications/{notificationId} {
      allow read: if isOwnerRole() || (isSignedIn() && sameCompany(resource.data.companyId) && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && sameCompany(request.resource.data.companyId)
        && (
          request.resource.data.userId == request.auth.uid
          || isAdminRole()
          || isOwnerRole()
        );
      allow update: if isSignedIn()
        && sameCompany(resource.data.companyId)
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read", "readAt", "updatedAt"]);
      allow delete: if false;
    }

    match /knowledgeSearchEvents/{eventId} {
      allow read: if isOwnerRole() || canReadCompanyData(resource.data.companyId);
      allow create: if isOwnerRole() || (
        isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && sameCompany(request.resource.data.companyId)
        && canUseKnowledgeDomain()
      );
      allow update, delete: if false;
    }

    match /salesActivityEvents/{eventId} {
      allow read: if isOwnerRole() || canReadCompanyData(resource.data.companyId);
      allow create: if isOwnerRole() || (
        isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && sameCompany(request.resource.data.companyId)
      );
      allow update, delete: if false;
    }

    match /audioProcessingJobs/{jobId} {
      allow read: if isOwnerRole() || canReadCompanyData(resource.data.companyId);
      allow create: if isOwnerRole() || (
        isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && sameCompany(request.resource.data.companyId)
      );
      allow update: if isOwnerRole()
        || canAdminCompanyData(resource.data.companyId)
        || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
          && sameCompany(resource.data.companyId)
        );
      allow delete: if false;
    }

    match /aiPrompts/{promptId} {
      allow read, create, update: if isOwnerRole();
      allow delete: if false;
    }

    match /featureFlags/{flagId} {
      allow read, create, update: if isOwnerRole();
      allow delete: if false;
    }

    match /announcements/{announcementId} {
      allow read, create, update: if isOwnerRole();
      allow delete: if false;
    }
  }
}
